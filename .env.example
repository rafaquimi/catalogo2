# ─────────────────────────────────────────────
# NEXT AUTH
# ─────────────────────────────────────────────
# Secreto para cifrar las sesiones (cadena larga y aleatoria)
NEXTAUTH_SECRET=CAMBIA-ESTO-POR-ALGO-LARGO-Y-ALEATORIO

# URL pública de tu app en Vercel (sin barra final)
NEXTAUTH_URL=https://tu-proyecto.vercel.app

# ─────────────────────────────────────────────
# SUPABASE / POSTGRESQL
# ─────────────────────────────────────────────
# Conexión con PgBouncer (pooler) — para la app en producción
# En Supabase: Project Settings → Database → Connection string → Transaction mode
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-xx-x.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Conexión directa — solo para migraciones (prisma db push / migrate deploy)
# En Supabase: Project Settings → Database → Connection string → Session mode (puerto 5432)
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-xx-x.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────
# CLOUDFLARE R2
# ─────────────────────────────────────────────
# Tu Account ID de Cloudflare (en el panel principal de Cloudflare, a la derecha)
R2_ACCOUNT_ID=tu-account-id

# Credenciales del token de API de R2
# En Cloudflare: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ACCESS_KEY_ID=tu-access-key-id
R2_SECRET_ACCESS_KEY=tu-secret-access-key

# Nombre del bucket que creaste en R2
R2_BUCKET_NAME=catalogos-imagenes

# URL pública del bucket (activar "Public Access" en el bucket de R2)
# Formato: https://pub-xxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev
